---
import Layout from '../layouts/Layout.astro';
import DiagnosticTool from '../components/DiagnosticTool';
import RegistrationForm from '../components/RegistrationForm';
import FaqAccordion from '../components/FaqAccordion';

// 5 Ejes Temáticos del Simposio (según PDF)
const ejesTematicos = [
  {
    num: "01",
    titulo: "Inteligencia Artificial Aplicada",
    enfoque: "¿Qué herramientas de IA puedo usar HOY en mi negocio para reducir costos y aumentar las ventas de forma real?",
    gradient: "from-blue-500 to-cyan-400",
  },
  {
    num: "02",
    titulo: "Automatización de Procesos",
    enfoque: "¿Cómo automatizar tareas repetitivas dentro de la estructura empresarial para ahorrar tiempo, optimizar recursos y dinero?",
    gradient: "from-violet-500 to-fuchsia-400",
  },
  {
    num: "03",
    titulo: "Casos de Éxito Replicables",
    enfoque: "Análisis de modelos internacionales de empresas similares que implementaron innovación y cómo adaptarlos al mercado local.",
    gradient: "from-cyan-500 to-emerald-400",
  },
  {
    num: "04",
    titulo: "Beneficios e Incentivos Tributarios",
    enfoque: "¿Cómo acceder a las deducciones tributarias de CONCYTEC y SUNAT por invertir activamente en innovación tecnológica?",
    gradient: "from-amber-500 to-orange-400",
  },
  {
    num: "05",
    titulo: "Financiamiento y Nuevos Mercados",
    enfoque: "Estrategias de articulación para acceder a fondos de financiamiento y escalar a mercados internacionales desde la región.",
    gradient: "from-red-500 to-violet-400",
  },
];

// Perfiles de los Ponentes por Confirmar
const speakers = [
  {
    num: "01",
    title: "Docente Internacional I",
    role: "IA Aplicada a los Negocios",
    expectedProfile: "Experto académico y corporativo con experiencia directiva en la integración de modelos de lenguaje e inteligencia artificial para la reducción de costos operativos y optimización de ventas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-blue-600/30 to-cyan-500/30 border-blue-500/30",
  },
  {
    num: "02",
    title: "Docente Internacional II",
    role: "Modelos de Innovación Corporativa",
    expectedProfile: "Investigador o consultor internacional especializado en la implementación de metodologías ágiles, transferencia tecnológica y optimización de rentabilidad en medianas y grandes empresas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-violet-600/30 to-fuchsia-500/30 border-violet-500/30",
  },
  {
    num: "03",
    title: "Docente Internacional III",
    role: "Escalabilidad y Expansión Regional",
    expectedProfile: "Empresario o académico regional con casos documentados de éxito guiando la internacionalización y el crecimiento de empresas andinas hacia mercados globales.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-cyan-600/30 to-emerald-500/30 border-cyan-500/30",
  },
  {
    num: "04",
    title: "Docente Nacional Invitado",
    role: "Gestión Pública y Beneficios Tributarios",
    expectedProfile: "Especialista operativo con conocimiento detallado en la formulación de proyectos de base tecnológica y acceso a las deducciones de impuestos (Ley Nº 30309).",
    origin: "Designación: CONCYTEC / SUNAT",
    avatarColor: "from-amber-600/30 to-orange-500/30 border-amber-500/30",
  },
];

// Cronograma oficial (según PDF)
const cronograma = [
  {
    time: "04:00 PM - 04:30 PM",
    block: "Acreditación & Exposición Inicial",
    title: "Registro & Exhibición de Startups",
    detail: "Acreditación formal. Exhibición exclusiva de startups de alto impacto con aplicación empresarial de las incubadoras de UNSA, UCSM, UCSP, UPT y UNAM. Estación de café premium permanente disponible.",
    glow: "border-slate-800",
  },
  {
    time: "04:30 PM - 04:40 PM",
    block: "Protocolo de Apertura",
    title: "Inauguración Oficial del Simposio",
    detail: "Palabras de bienvenida a cargo del Vicerrector de Investigación de la UNSA y la Directora de la Red Universitaria de Innovación (RUI).",
    glow: "border-slate-800",
  },
  {
    time: "04:40 PM - 05:10 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Keynote: Inteligencia Artificial Aplicada a los Negocios",
    detail: "Herramientas concretas de IA para automatizar flujos de trabajo, reducir costos operativos directos y potenciar las ventas comerciales de la organización.",
    glow: "border-blue-500/35 bg-blue-950/10",
  },
  {
    time: "05:10 PM - 05:50 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Panel Empresarial: ¿Qué está funcionando hoy en la empresa local?",
    detail: "Debate abierto con 4 empresarios líderes de la región que ya han integrado tecnología e IA en sus procesos de negocio. Ronda de preguntas del público.",
    glow: "border-blue-500/35 bg-blue-950/10",
  },
  {
    time: "05:50 PM - 06:20 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Keynote: Modelos de Innovación Replicables y Rentabilidad",
    detail: "Casos de éxito internacionales. Análisis detallado de cómo medianas y grandes empresas transformaron radicalmente su rentabilidad con metodologías replicables.",
    glow: "border-violet-500/35 bg-violet-950/10",
  },
  {
    time: "06:20 PM - 06:50 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Conferencia: Incentivos y Beneficios Tributarios para Innovación",
    detail: "Explicación operativa para acceder a las deducciones de impuestos ante CONCYTEC y SUNAT por inversión en tecnología desde la región Arequipa.",
    glow: "border-violet-500/35 bg-violet-950/10",
  },
  {
    time: "06:50 PM - 07:30 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Panel Multilaterial: Financiamiento, Mercados Globales y Alianzas",
    detail: "Panelistas: Representante de CONCYTEC + Empresario Exitoso Regional + Ponente Internacional. Discusión sobre financiamiento corporativo y acceso a mercados internacionales.",
    glow: "border-violet-500/35 bg-violet-950/10",
  },
  {
    time: "07:30 PM - 07:35 PM",
    block: "Networking Estructurado",
    title: "Dinámica de Conexión Rápida (Elevator Pitch)",
    detail: "Dirección a cargo del MC para que cada asistente presente su empresa en 30 segundos a un nuevo colega empresario. Rompiendo el hielo corporativo.",
    glow: "border-slate-800",
  },
  {
    time: "07:35 PM - 08:00 PM",
    block: "Networking Estructurado",
    title: "Cóctel de Networking Corporativo & Cierre",
    detail: "Bebidas y bocaditos variados en un ambiente privado. Facilitadores de la UNSA presentarán y conectarán empresarios, ponentes y autoridades para concretar acuerdos e inversión.",
    glow: "border-cyan-500/35 bg-cyan-950/10",
  },
];
---

<Layout title="III Simposio Internacional - Desarrollo e Innovación Empresarial">
  
  <!-- Academic Top Banner -->
  <div class="bg-slate-950/90 border-b border-slate-900 text-[10px] font-black text-slate-400 py-3 relative z-30">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-3 text-center md:text-left">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="text-cyan-400 font-extrabold uppercase tracking-widest">Organiza:</span>
        <span class="text-white font-bold">Universidad Nacional de San Agustín de Arequipa (UNSA)</span>
        <span class="text-slate-800 hidden md:inline">|</span>
        <span class="text-slate-350">Dirección de Innovación y Transferencia Tecnológica</span>
      </div>
      <div class="flex items-center justify-center gap-2">
        <span class="text-violet-400 font-extrabold uppercase tracking-widest">Co-organizadores:</span>
        <span class="text-white font-bold">UCSM • UCSP • UPT • UNAM</span>
      </div>
    </div>
  </div>

  <!-- Glass Sticky Header -->
  <header class="sticky top-0 z-45 backdrop-blur-md bg-slate-950/70 border-b border-slate-900/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 h-22 flex items-center justify-between">
      
      <!-- Brand Logo -->
      <a href="#" class="flex items-center space-x-3.5 group">
        <div class="w-11 h-11 rounded-2xl bg-gradient-to-tr from-blue-600 to-violet-600 border border-violet-500/30 flex items-center justify-center shadow-lg shadow-violet-950/20 transition-transform duration-300 group-hover:scale-105">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-lg font-black font-outfit text-white tracking-tight uppercase leading-none">
            III Simposio <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-blue-400 to-violet-400">Internacional</span>
          </span>
          <span class="text-[9px] text-slate-500 font-black uppercase tracking-widest mt-1">
            Desarrollo Empresarial Arequipa
          </span>
        </div>
      </a>

      <!-- Desktop Links -->
      <nav class="hidden lg:flex items-center space-x-8 text-xs font-black uppercase tracking-wider text-slate-400">
        <a href="#objetivo" class="hover:text-white transition-colors">Propósito</a>
        <a href="#ejes" class="hover:text-white transition-colors">Ejes</a>
        <a href="#diagnostic" class="hover:text-white transition-colors">Autodiagnóstico</a>
        <a href="#agenda" class="hover:text-white transition-colors">Programa</a>
        <a href="#ponentes" class="hover:text-white transition-colors">Ponentes</a>
        <a href="#faq" class="hover:text-white transition-colors">Ayuda</a>
      </nav>

      <!-- Exclusive CTA -->
      <div class="hidden lg:flex items-center">
        <a 
          href="#register" 
          class="inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 text-white hover:opacity-95 shadow-md shadow-violet-950/20 hover:scale-[1.02] active:scale-[0.98] transition-all"
        >
          Postular al Registro
        </a>
      </div>

      <!-- Hamburger mobile button -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-xl text-slate-400 hover:text-white hover:bg-slate-900 transition-colors focus:outline-none"
        aria-label="Abrir menú móvil"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation Menu -->
    <div 
      id="mobile-nav" 
      class="hidden lg:hidden bg-slate-950/95 backdrop-blur-md border-b border-slate-900 px-6 py-6 space-y-4 shadow-xl"
    >
      <a href="#objetivo" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Propósito</a>
      <a href="#ejes" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Ejes Temáticos</a>
      <a href="#diagnostic" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Autodiagnóstico</a>
      <a href="#agenda" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Programa</a>
      <a href="#ponentes" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Ponentes</a>
      <a href="#faq" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Preguntas</a>
      <div class="pt-2">
        <a 
          href="#register" 
          class="mobile-link w-full inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-gradient-to-r from-blue-600 to-violet-600 text-white"
        >
          Postular al Registro
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative pt-12 pb-24 lg:pt-20 lg:pb-36 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Content -->
        <div class="lg:col-span-7 text-center lg:text-left space-y-8 animate-[fadeIn_0.6s_ease-out]">
          
          <div class="inline-flex items-center space-x-2.5 bg-violet-500/10 border border-violet-500/30 px-5 py-2 rounded-full text-[10px] font-black text-violet-300 tracking-widest uppercase shadow-md shadow-violet-950/20">
            <span class="w-2.5 h-2.5 rounded-full bg-cyan-400 animate-ping"></span>
            <span>Encuentro de Innovación y Creadores de Futuro</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-black tracking-tight text-white leading-[1.08] font-outfit">
            El Futuro de la Innovación:<br />
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-blue-500 to-violet-400 animate-pulse-slow">
              Conecta, Aprende y Transforma
            </span>
          </h1>

          <p class="text-base sm:text-lg text-slate-400 font-semibold leading-relaxed max-w-2xl mx-auto lg:mx-0">
            ¡Te damos la bienvenida al evento de innovación y tecnología más dinámico del macrosur! Diseñamos este espacio para conectar de forma inspiradora a <strong>emprendedores, líderes, empresas y universidades</strong>, facilitando que aprendas sobre IA de negocio, automatización y beneficios fiscales de forma sumamente sencilla y colaborativa.
          </p>

          <!-- Quick Metadata Bar -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-6 border-y border-slate-900 max-w-xl mx-auto lg:mx-0">
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-cyan-400 shrink-0">
                📅
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Fecha</div>
                <div class="text-xs font-black text-white">Miér. 1 de Julio, 2026</div>
              </div>
            </div>
            
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-violet-400 shrink-0">
                ⏰
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Horario</div>
                <div class="text-xs font-black text-white">4:00 PM – 8:00 PM</div>
              </div>
            </div>

            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-blue-400 shrink-0">
                📍
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Lugar</div>
                <div class="text-xs font-black text-white">Cámara de Comercio - AQP</div>
              </div>
            </div>
          </div>

          <!-- Hero CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a 
              href="#register" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-gradient-to-r from-blue-600 via-violet-600 to-cyan-500 text-white hover:opacity-95 shadow-xl hover:shadow-violet-950/20 hover:scale-[1.01] active:scale-[0.99] transition-all"
            >
              Postular al Registro
            </a>
            <a 
              href="#agenda" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-slate-900 border border-slate-800 text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all"
            >
              Ver Programa Oficial
            </a>
          </div>

        </div>

        {/* Right Column: Premium Digital Pass Illustration */}
        <div class="lg:col-span-5 relative flex justify-center">
          <div class="absolute inset-0 bg-gradient-to-tr from-violet-600/10 to-cyan-500/10 rounded-3xl blur-2xl -z-10"></div>
          
          <div class="relative w-full max-w-[390px] bg-slate-900/60 backdrop-blur-xl border border-slate-800/80 rounded-3xl p-8 shadow-2xl flex flex-col justify-between overflow-hidden group">
            
            {/* Gloss light edge */}
            <div class="absolute top-[-50px] right-[-50px] w-36 h-36 bg-cyan-400/5 rounded-full blur-2xl group-hover:bg-cyan-400/10 transition-colors duration-500"></div>

            {/* Ticket Header */}
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-[9px] font-black text-violet-400 bg-violet-950/50 border border-violet-850 px-3 py-1 rounded-full uppercase tracking-wider">
                  Acceso Exclusivo (Gratuito)
                </span>
                <span class="text-[10px] text-slate-500 font-bold tracking-widest uppercase">100 Invitados</span>
              </div>
              <h3 class="text-xl sm:text-2xl font-black text-white tracking-tight leading-snug font-outfit text-left">
                III Simposio de Innovación & Desarrollo Empresarial
              </h3>
              <p class="text-xs sm:text-sm text-slate-400 font-semibold leading-relaxed text-left">
                Acompáñanos en una jornada inspiradora diseñada para descubrir casos reales de IA, automatización inteligente e incentivos de innovación de una forma sumamente cercana, interactiva y dinámica.
              </p>
            </div>

            {/* Features list inside card */}
            <div class="my-6 bg-slate-950/80 border border-slate-850 rounded-2xl p-4.5 space-y-3.5 shadow-inner">
              <div class="flex items-center space-x-3 text-xs font-bold text-slate-300 text-left">
                <span class="text-cyan-400 text-sm">✨</span>
                <span>Encuentro cercano entre líderes y creadores</span>
              </div>
              <div class="flex items-center space-x-3 text-xs font-bold text-slate-300 text-left">
                <span class="text-cyan-400 text-sm">💡</span>
                <span>Exhibición de Startups de Alto Impacto</span>
              </div>
              <div class="flex items-center space-x-3 text-xs font-bold text-slate-300 text-left">
                <span class="text-cyan-400 text-sm">🍸</span>
                <span>Cóctel de Networking Estructurado</span>
              </div>
            </div>

            {/* Ticket Footer details */}
            <div class="flex items-center justify-between pt-4 border-t border-slate-800/80 text-[10px] text-slate-500 font-black uppercase tracking-wider">
              <span>Formato Presencial</span>
              <span class="text-cyan-400">CCIA Arequipa</span>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Section: Propósito y Visión (Bridge Layout) -->
  <section id="objetivo" class="py-24 bg-slate-950/60 border-t border-b border-slate-900 relative">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Content -->
        <div class="lg:col-span-6 space-y-6 text-left animate-[fadeIn_0.6s_ease-out]">
          <span class="text-[10px] font-black text-violet-400 bg-violet-950/50 border border-violet-850 rounded-md px-3.5 py-1.5 w-max block uppercase tracking-widest">
            Propósito y Visión
          </span>
          <h2 class="text-3xl sm:text-4xl font-black text-white tracking-tight leading-snug font-outfit">
            Un Puente Colaborativo para Crecer Juntos
          </h2>
          <p class="text-slate-350 text-sm sm:text-base font-semibold leading-relaxed">
            Creemos firmemente en el poder del trabajo en equipo. Este simposio conecta de manera ágil el talento tecnológico de la UNSA y universidades aliadas con la energía y visión de nuestros emprendedores y empresas regionales. Juntos dinamizamos el macrosur, creamos empleo de calidad y abrimos nuevas oportunidades de expansión regional.
          </p>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-4">
            <div class="space-y-2.5">
              <div class="text-sm font-black text-white flex items-center space-x-2">
                <span class="w-2 h-2 rounded-full bg-cyan-400 shrink-0"></span>
                <span>Rentabilidad Práctica</span>
              </div>
              <p class="text-xs text-slate-400 leading-relaxed font-semibold">
                Casos reales de IA y automatización aplicados en empresas locales para optimizar costos de inmediato sin tecnicismos complejos.
              </p>
            </div>
            <div class="space-y-2.5">
              <div class="text-sm font-black text-white flex items-center space-x-2">
                <span class="w-2 h-2 rounded-full bg-violet-400 shrink-0"></span>
                <span>Networking Estructurado</span>
              </div>
              <p class="text-xs text-slate-400 leading-relaxed font-semibold">
                En un entorno cerrado con un aforo filtrado de 100 personas, conéctese activamente con tomadores de decisión mediante facilitadores de sala.
              </p>
            </div>
          </div>
        </div>

        {/* Right Content: Co-organizadores & Roles (Section VI) */}
        <div class="lg:col-span-6">
          <div class="bg-slate-900/60 backdrop-blur-md border border-slate-800 rounded-3xl p-8 space-y-6 shadow-xl text-left">
            <h3 class="text-lg font-black text-white border-b border-slate-850 pb-4 flex items-center gap-2">
              <span>🤝</span> Sinergia Regional Coorganizadora
            </h3>
            <p class="text-xs sm:text-sm text-slate-400 leading-relaxed font-semibold">
              Las universidades socias (<strong class="text-white">UCSM, UCSP, UPT y UNAM</strong>) participan con roles técnicos y científicos específicos para elevar la calidad internacional del simposio:
            </p>
            <div class="space-y-4">
              <div class="flex items-start space-x-4">
                <div class="w-9 h-9 rounded-xl bg-violet-950/80 border border-violet-850 flex items-center justify-center text-violet-400 shrink-0 font-black text-xs">
                  A
                </div>
                <div>
                  <div class="text-xs font-black text-white">Reclutamiento Científico</div>
                  <p class="text-[11px] text-slate-400 leading-normal mt-0.5 font-medium">Cada universidad socia recluta y confirma a un ponente internacional de primer nivel tecnológico.</p>
                </div>
              </div>
              <div class="flex items-start space-x-4">
                <div class="w-9 h-9 rounded-xl bg-cyan-950/80 border border-cyan-850 flex items-center justify-center text-cyan-400 shrink-0 font-black text-xs">
                  B
                </div>
                <div>
                  <div class="text-xs font-black text-white">Exhibición de Incubadoras</div>
