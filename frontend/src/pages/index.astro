---
import Layout from '../layouts/Layout.astro';
import DiagnosticTool from '../components/DiagnosticTool';
import RegistrationForm from '../components/RegistrationForm';
import FaqAccordion from '../components/FaqAccordion';

// 5 Ejes Temáticos del Simposio (según PDF)
const ejesTematicos = [
  {
    num: "01",
    titulo: "Inteligencia Artificial Aplicada",
    enfoque: "¿Qué herramientas de IA puedo usar HOY en mi negocio para reducir costos y aumentar las ventas de forma real?",
    gradient: "from-blue-500 to-cyan-400",
  },
  {
    num: "02",
    titulo: "Automatización de Procesos",
    enfoque: "¿Cómo automatizar tareas repetitivas dentro de la estructura empresarial para ahorrar tiempo, optimizar recursos y dinero?",
    gradient: "from-violet-500 to-fuchsia-400",
  },
  {
    num: "03",
    titulo: "Casos de Éxito Replicables",
    enfoque: "Análisis de modelos internacionales de empresas similares que implementaron innovación y cómo adaptarlos al mercado local.",
    gradient: "from-cyan-500 to-emerald-400",
  },
  {
    num: "04",
    titulo: "Beneficios e Incentivos Tributarios",
    enfoque: "¿Cómo acceder a las deducciones tributarias de CONCYTEC y SUNAT por invertir activamente en innovación tecnológica?",
    gradient: "from-amber-500 to-orange-400",
  },
  {
    num: "05",
    titulo: "Financiamiento y Nuevos Mercados",
    enfoque: "Estrategias de articulación para acceder a fondos de financiamiento y escalar a mercados internacionales desde la región.",
    gradient: "from-red-500 to-violet-400",
  },
];

// Perfiles de los Ponentes por Confirmar
const speakers = [
  {
    num: "01",
    title: "Docente Internacional I",
    role: "IA Aplicada a los Negocios",
    expectedProfile: "Experto académico y corporativo con experiencia directiva en la integración de modelos de lenguaje e inteligencia artificial para la reducción de costos operativos y optimización de ventas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-blue-600/30 to-cyan-500/30 border-blue-500/30",
  },
  {
    num: "02",
    title: "Docente Internacional II",
    role: "Modelos de Innovación Corporativa",
    expectedProfile: "Investigador o consultor internacional especializado en la implementación de metodologías ágiles, transferencia tecnológica y optimización de rentabilidad en medianas y grandes empresas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-violet-600/30 to-fuchsia-500/30 border-violet-500/30",
  },
  {
    num: "03",
    title: "Docente Internacional III",
    role: "Escalabilidad y Expansión Regional",
    expectedProfile: "Empresario o académico regional con casos documentados de éxito guiando la internacionalización y el crecimiento de empresas andinas hacia mercados globales.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-cyan-600/30 to-emerald-500/30 border-cyan-500/30",
  },
  {
    num: "04",
    title: "Docente Nacional Invitado",
    role: "Gestión Pública y Beneficios Tributarios",
    expectedProfile: "Especialista operativo con conocimiento detallado en la formulación de proyectos de base tecnológica y acceso a las deducciones de impuestos (Ley Nº 30309).",
    origin: "Designación: CONCYTEC / SUNAT",
    avatarColor: "from-amber-600/30 to-orange-500/30 border-amber-500/30",
  },
];

const cronograma = [
  {
    time: "04:00 PM - 04:30 PM",
    block: "Acreditación & Exposición Inicial",
    title: "Registro & Exhibición de Startups",
    detail: "Acreditación formal. Exhibición exclusiva de startups de alto impacto con aplicación empresarial de las incubadoras de UNSA, UCSM, UCSP, UPT y UNAM. Estación de café premium permanente disponible.",
    glow: "border-slate-800",
  },
  {
    time: "04:30 PM - 04:40 PM",
    block: "Protocolo de Apertura",
    title: "Inauguración Oficial del Simposio",
    detail: "Palabras de bienvenida a cargo del Vicerrector de Investigación de la UNSA, la Gerencia Regional de Ciencia, Tecnología e Innovación (GORE) y la Directora de la Red Universitaria de Innovación (RUI).",
    glow: "border-slate-800",
  },
  {
    time: "04:40 PM - 05:10 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Keynote: Inteligencia Artificial Aplicada a los Negocios",
    detail: "Herramientas concretas de IA para automatizar flujos de trabajo, reducir costos operativos directos y potenciar las ventas comerciales de la organización.",
    glow: "border-neon-cyan/20 bg-neon-cyan/5",
  },
  {
    time: "05:10 PM - 05:50 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Panel Empresarial: ¿Qué está funcionando hoy en la empresa local?",
    detail: "Debate abierto con empresarios líderes de la región y la Municipalidad Provincial de Arequipa (como panelista invitado) analizando la adopción real de tecnología e IA en los negocios locales.",
    glow: "border-neon-cyan/20 bg-neon-cyan/5",
  },
  {
    time: "05:50 PM - 06:20 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Keynote: Modelos de Innovación Replicables y Rentabilidad",
    detail: "Casos de éxito internacionales. Análisis detallado de cómo medianas y grandes empresas transformaron radicalmente su rentabilidad con metodologías replicables.",
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "06:20 PM - 06:50 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Conferencia: Incentivos y Beneficios Tributarios para Innovación",
    detail: "Explicación operativa para acceder a las deducciones de impuestos ante CONCYTEC y SUNAT por inversión en tecnología desde la región Arequipa.",
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "06:50 PM - 07:30 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Panel Multilateral: Financiamiento, Mercados Globales y Alianzas",
    detail: "Panelistas: Representante de CONCYTEC + Gobierno Regional de Arequipa (GORE) + Empresario Exitoso Regional + Ponente Internacional. Discusión sobre financiamiento corporativo y acceso a mercados internacionales.",
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "07:30 PM - 07:35 PM",
    block: "Networking Estructurado",
    title: "Dinámica de Conexión Rápida (Elevator Pitch)",
    detail: "Dirección a cargo del MC para que cada asistente presente su empresa en 30 segundos a un nuevo colega empresario. Rompiendo el hielo corporativo.",
    glow: "border-slate-800",
  },
  {
    time: "07:35 PM - 08:00 PM",
    block: "Networking Estructurado",
    title: "Cóctel de Networking Corporativo & Cierre",
    detail: "Bebidas y bocaditos variados en un ambiente privado. Facilitadores de la UNSA presentarán y conectarán empresarios, ponentes y autoridades (incluyendo delegados de la Municipalidad y del GORE) para concretar acuerdos.",
    glow: "border-neon-cyan/25 bg-neon-cyan/5",
  },
];
---

<Layout title="III Simposio Internacional - Desarrollo e Innovación Empresarial">
  
  <!-- Academic Top Banner -->
  <div class="bg-white border-b border-slate-200 text-[10px] py-3.5 relative z-30 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 flex flex-col xl:flex-row items-center justify-between gap-3 text-center xl:text-left">
      <div class="flex flex-wrap items-center justify-center gap-2 text-slate-800 font-bold">
        <span class="text-[#800020] font-black uppercase tracking-wider">Organiza:</span>
        <span class="text-slate-900 font-extrabold">Universidad Nacional de San Agustín de Arequipa (UNSA)</span>
        <span class="text-slate-300 hidden md:inline">|</span>
        <span class="text-[#800020] font-extrabold">Vicerrectorado de Investigación</span>
        <span class="text-slate-300 hidden md:inline">|</span>
        <span class="text-slate-600 font-medium">Dirección de Innovación y Transferencia Tecnológica</span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 text-slate-700 font-bold">
        <span class="text-[#800020] font-black uppercase tracking-wider">Co-organizadores:</span>
        <span class="text-slate-800 font-extrabold">UCSM • UCSP • UPT • UNAM</span>
        <span class="text-slate-300 hidden md:inline">•</span>
        <a 
          href="https://www.facebook.com/p/Gerencia-Regional-de-Ciencia-Tecnolog%C3%ADa-e-Innovaci%C3%B3n-61559188270311/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="text-blue-600 hover:text-blue-800 font-black hover:underline flex items-center gap-1 transition-all"
        >
          GORE Arequipa (Gerencia Regional de Ciencia, Tecnología e Innovación)
        </a>
      </div>
    </div>
  </div>

  <!-- Glass Sticky Header -->
  <header class="sticky top-0 z-45 backdrop-blur-md bg-slate-950/70 border-b border-slate-900/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 h-22 flex items-center justify-between">
      
      <!-- Brand Logo -->
      <a href="#" class="flex items-center space-x-3.5 group">
        <div class="w-11 h-11 rounded-2xl bg-gradient-to-tr from-neon-lime to-neon-cyan border border-neon-lime/30 flex items-center justify-center shadow-lg shadow-cyan-950/20 transition-transform duration-300 group-hover:scale-105">
          <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-base sm:text-lg font-black font-outfit text-white tracking-tight uppercase leading-none">
            III Simposio <span class="bg-clip-text text-transparent bg-neon-lime">Internacional</span>
          </span>
          <span class="text-[8px] sm:text-[9px] text-slate-500 font-black uppercase tracking-widest mt-1">
            Desarrollo Empresarial Arequipa
          </span>
        </div>
      </a>

      <!-- Desktop Links -->
      <nav class="hidden lg:flex items-center space-x-8 text-xs font-black uppercase tracking-wider text-slate-400">
        <a href="#objetivo" class="hover:text-white transition-colors">Propósito</a>
        <a href="#ejes" class="hover:text-white transition-colors">Ejes</a>
        <a href="#diagnostic" class="hover:text-white transition-colors">Autodiagnóstico</a>
        <a href="#agenda" class="hover:text-white transition-colors">Programa</a>
        <a href="#ponentes" class="hover:text-white transition-colors">Ponentes</a>
        <a href="#faq" class="hover:text-white transition-colors">Ayuda</a>
      </nav>

      <!-- Exclusive CTA -->
      <div class="hidden lg:flex items-center">
        <a 
          href="#register" 
          class="inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-neon-lime text-black hover:opacity-95 shadow-md shadow-cyan-950/20 hover:scale-[1.02] active:scale-[0.98] transition-all font-black"
        >
          Postular al Registro
        </a>
      </div>

      <!-- Hamburger mobile button -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-xl text-slate-400 hover:text-white hover:bg-slate-900 transition-colors focus:outline-none"
        aria-label="Abrir menú móvil"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation Menu -->
    <div 
      id="mobile-nav" 
      class="hidden lg:hidden bg-slate-950/95 backdrop-blur-md border-b border-slate-900 px-6 py-6 space-y-4 shadow-xl"
    >
      <a href="#objetivo" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Propósito</a>
      <a href="#ejes" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Ejes Temáticos</a>
      <a href="#diagnostic" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Autodiagnóstico</a>
      <a href="#agenda" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Programa</a>
      <a href="#ponentes" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Ponentes</a>
      <a href="#faq" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Preguntas</a>
      <div class="pt-2">
        <a 
          href="#register" 
          class="mobile-link w-full inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-neon-lime text-black font-black"
        >
          Postular al Registro
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative pt-12 pb-24 lg:pt-20 lg:pb-36 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Content -->
        <div class="lg:col-span-7 text-center lg:text-left space-y-8 animate-[fadeIn_0.6s_ease-out]">
          
          <div class="inline-flex items-center space-x-2.5 bg-neon-lime/10 border border-neon-lime/30 px-5 py-2 rounded-full text-[10px] font-black text-neon-lime tracking-widest uppercase shadow-md shadow-cyan-950/20">
            <span class="w-2.5 h-2.5 rounded-full bg-neon-lime animate-ping"></span>
            <span>Encuentro de Innovación y Creadores de Futuro</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-black tracking-tight text-white leading-[1.08] font-outfit">
            El Futuro de la Innovación:<br />
            <span class="text-neon-lime">
              Conecta, Aprende y Transforma
            </span>
          </h1>

          <p class="text-base sm:text-lg text-slate-400 font-semibold leading-relaxed max-w-2xl mx-auto lg:mx-0">
            ¡Te damos la bienvenida al evento de innovación y tecnología más dinámico del macrosur! Diseñamos este espacio para conectar de forma inspiradora a <strong>emprendedores, líderes, empresas y universidades</strong>, facilitando que aprendas sobre IA de negocio, automatización y beneficios fiscales de forma sumamente sencilla y colaborativa.
          </p>

          <!-- Quick Metadata Bar -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-6 border-y border-slate-900 max-w-xl mx-auto lg:mx-0">
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-cyan shrink-0">
                📅
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Fecha</div>
                <div class="text-xs font-black text-white">Miér. 1 de Julio, 2026</div>
              </div>
            </div>
            
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-lime shrink-0">
                ⏰
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Horario</div>
                <div class="text-xs font-black text-white">4:00 PM – 8:00 PM</div>
              </div>
            </div>

            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-cyan shrink-0">
                📍
              </div>
              <div class="text-left">
                <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Lugar</div>
                <div class="text-xs font-black text-white">Cámara de Comercio - AQP</div>
              </div>
            </div>
          </div>

          <!-- Hero CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a 
              href="#register" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-neon-lime text-black hover:opacity-95 shadow-xl hover:shadow-cyan-950/20 hover:scale-[1.01] active:scale-[0.99] transition-all font-black"
            >
              Postular al Registro
            </a>
            <a 
              href="#agenda" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-slate-900 border border-slate-800 text-slate-350 hover:text-white hover:bg-slate-800 transition-all"
            >
              Ver Programa Oficial
            </a>
          </div>

        </div>

        {/* Right Column: Interactive Flyer Mockup */}
        <div class="lg:col-span-5 relative flex justify-center w-full">
          <div class="absolute inset-0 bg-gradient-to-tr from-neon-lime/10 to-neon-cyan/15 rounded-3xl blur-2xl -z-10 animate-pulse-slow"></div>
          
          <div class="relative w-full max-w-[430px] bg-[#010915] border border-slate-800 rounded-3xl p-6 sm:p-10 shadow-2xl flex flex-col justify-between overflow-hidden group hover:border-neon-lime/40 transition-all duration-500 min-h-[550px]">
            
            {/* Mesh background effect */}
            <div class="absolute inset-0 bg-[radial-gradient(#00f0ff_1.2px,transparent_1.2px)] bg-[size:24px_24px] opacity-15 pointer-events-none"></div>
            
            {/* Ambient glows inside flyer card */}
            <div class="absolute top-1/4 left-1/4 w-32 h-32 bg-neon-cyan/15 rounded-full blur-2xl pointer-events-none"></div>
            <div class="absolute bottom-1/4 right-1/4 w-32 h-32 bg-neon-lime/10 rounded-full blur-2xl pointer-events-none"></div>

            {/* Flyer Content Header */}
            <div class="text-left space-y-4.5 z-10 relative">
              
              {/* Title Section (Matching Flyer Typography) */}
              <div class="flex items-start gap-4.5">
                <div class="text-6xl sm:text-[76px] font-black text-neon-lime leading-[0.8] tracking-tighter select-none font-outfit">
                  III
                </div>
                <div class="flex flex-col text-left">
                  <span class="text-3xl sm:text-[38px] font-black text-white tracking-tight leading-[0.9] font-outfit uppercase">
                    Simposio
                  </span>
                  <span class="text-2xl sm:text-[32px] font-black text-neon-lime tracking-tight leading-[0.9] font-outfit uppercase">
                    Internacional
                  </span>
                </div>
              </div>
              
              <p class="text-slate-300 font-bold text-xs sm:text-[13px] tracking-wide mt-2 border-l-2 border-neon-lime pl-3.5">
                Tecnología, innovación y desarrollo empresarial.
              </p>
            </div>

            {/* Flyer Middle: Date & Place (with Lime Icons) */}
            <div class="my-8 space-y-4.5 z-10 relative">
              {/* Date */}
              <div class="flex items-center space-x-4 text-left">
                <div class="w-11 h-11 rounded-xl bg-slate-950/80 border border-slate-800 flex items-center justify-center shrink-0 shadow-inner group-hover:border-neon-lime/30 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-neon-lime"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                </div>
                <div>
                  <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Fecha</div>
                  <div class="text-xs font-black text-white">Miércoles 1 de Julio — 16:00 hrs</div>
                </div>
              </div>

              {/* Place */}
              <div class="flex items-center space-x-4 text-left">
                <div class="w-11 h-11 rounded-xl bg-slate-950/80 border border-slate-800 flex items-center justify-center shrink-0 shadow-inner group-hover:border-neon-lime/30 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-neon-lime"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <div class="text-[9px] text-slate-500 font-black uppercase tracking-widest">Lugar</div>
                  <div class="text-xs font-black text-white">Cámara de Comercio e Industria - AQP</div>
                </div>
              </div>
            </div>

            {/* Flyer Lower: Próximamente Progress Bar & Slogan */}
            <div class="space-y-6 pt-6 border-t border-slate-850 z-10 relative text-center">
              
              {/* Próximamente Glow text */}
              <div class="space-y-2.5">
                <div class="text-[13px] font-black text-neon-cyan uppercase tracking-[0.25em] drop-shadow-[0_0_8px_rgba(0,240,255,0.4)] animate-pulse">
                  PRÓXIMAMENTE
                </div>
                
                {/* Visual block progress bar */}
                <div class="w-full max-w-[300px] mx-auto h-7 border border-slate-800/80 rounded-xl p-1 flex gap-1.5 items-center bg-slate-950/80 shadow-inner">
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white rounded-[4px] opacity-90"></div>
                  <div class="flex-1 h-full bg-white/15 rounded-[4px]"></div>
                  <div class="flex-1 h-full bg-white/15 rounded-[4px]"></div>
                  <div class="flex-1 h-full bg-white/15 rounded-[4px]"></div>
                </div>
              </div>

              {/* Italic Slogan */}
              <p class="text-[11px] text-slate-350 font-semibold italic">
                "Un espacio para innovar, transformar y crecer"
              </p>

              {/* Social circles */}
              <div class="flex items-center justify-center gap-3.5 pt-1 text-slate-400">
                <a 
                  href="https://www.facebook.com/DITTUNSA" 
