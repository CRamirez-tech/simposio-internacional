---
import Layout from '../layouts/Layout.astro';
import FaqAccordion from '../components/FaqAccordion';
import Logo from '../components/Logo.astro';

// 5 Ejes Temáticos del Simposio (según PDF)
const ejesTematicos = [
  {
    num: "01",
    titulo: "Inteligencia Artificial Aplicada",
    enfoque: "¿Qué herramientas de IA puedo usar HOY en mi negocio para reducir costos y aumentar las ventas de forma real?",
    gradient: "from-blue-500 to-cyan-400",
  },
  {
    num: "02",
    titulo: "Automatización de Procesos",
    enfoque: "¿Cómo automatizar tareas repetitivas dentro de la estructura empresarial para ahorrar tiempo, optimizar recursos y dinero?",
    gradient: "from-violet-500 to-fuchsia-400",
  },
  {
    num: "03",
    titulo: "Casos de Éxito Replicables",
    enfoque: "Análisis de modelos internacionales de empresas similares que implementaron innovación y cómo adaptarlos al mercado local.",
    gradient: "from-cyan-500 to-emerald-400",
  },
  {
    num: "04",
    titulo: "Beneficios e Incentivos Tributarios",
    enfoque: "¿Cómo acceder a las deducciones tributarias de CONCYTEC y SUNAT por invertir activamente en innovación tecnológica?",
    gradient: "from-amber-500 to-orange-400",
  },
  {
    num: "05",
    titulo: "Financiamiento y Nuevos Mercados",
    enfoque: "Estrategias de articulación para acceder a fondos de financiamiento y escalar a mercados internacionales desde la región.",
    gradient: "from-red-500 to-violet-400",
  },
];

// Perfiles de los Ponentes por Confirmar
const speakers = [
  {
    num: "01",
    title: "Docente Internacional I",
    role: "IA Aplicada a los Negocios",
    expectedProfile: "Experto académico y corporativo con experiencia directiva en la integración de modelos de lenguaje e inteligencia artificial para la reducción de costos operativos y optimización de ventas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-blue-600/30 to-cyan-500/30 border-blue-500/30",
  },
  {
    num: "02",
    title: "Docente Internacional II",
    role: "Modelos de Innovación Corporativa",
    expectedProfile: "Investigador o consultor internacional especializado en la implementación de metodologías ágiles, transferencia tecnológica y optimización de rentabilidad en medianas y grandes empresas.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-violet-600/30 to-fuchsia-500/30 border-violet-500/30",
  },
  {
    num: "03",
    title: "Docente Internacional III",
    role: "Escalabilidad y Expansión Regional",
    expectedProfile: "Empresario o académico regional con casos documentados de éxito guiando la internacionalización y el crecimiento de empresas andinas hacia mercados globales.",
    origin: "Convocatoria: Universidad Coorganizadora",
    avatarColor: "from-cyan-600/30 to-emerald-500/30 border-cyan-500/30",
  },
  {
    num: "04",
    title: "Docente Nacional Invitado",
    role: "Gestión Pública y Beneficios Tributarios",
    expectedProfile: "Especialista operativo con conocimiento detallado en la formulación de proyectos de base tecnológica y acceso a las deducciones de impuestos (Ley Nº 30309).",
    origin: "Designación: CONCYTEC / SUNAT",
    avatarColor: "from-amber-600/30 to-orange-500/30 border-amber-500/30",
  },
];

const cronograma = [
  {
    time: "04:00 PM - 04:30 PM",
    block: "Registro de participantes",
    title: "Registro de participantes",
    detail: "Acreditación y registro formal.",
    glow: "border-slate-800",
  },
  {
    time: "04:30 PM - 04:40 PM",
    block: "Protocolo de Apertura",
    title: "Inauguración Oficial del Simposio",
    detail: "Bienvenida del Vicerrector de Investigación (UNSA) y la Directora de la RUI.",
    glow: "border-slate-800",
  },
  {
    time: "04:40 PM - 05:10 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Ponencia: Inteligencia Artificial Aplicada a los Negocios",
    detail: "Uso de herramientas de IA para optimizar flujos de trabajo y reducir costos.",
    speaker: "Docente Internacional I",
    organizer: "IA & Negocios",
    glow: "border-neon-cyan/20 bg-neon-cyan/5",
  },
  {
    time: "05:10 PM - 05:50 PM",
    block: "BLOQUE 1: Tecnología e IA",
    title: "Panel Empresarial: ¿Qué está funcionando hoy en la empresa local?",
    detail: "Adopción real de tecnología e IA en la industria local.",
    speakers: ["Empresarios líderes regionales", "Representante de la Municipalidad de Arequipa"],
    glow: "border-neon-cyan/20 bg-neon-cyan/5",
  },
  {
    time: "05:50 PM - 06:20 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Ponencia: Modelos de Innovación Replicables y Rentabilidad",
    detail: "Metodologías globales de transformación de rentabilidad.",
    speaker: "Docente Internacional II",
    organizer: "Modelos de Innovación",
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "06:20 PM - 06:50 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Conferencia: Incentivos y Beneficios Tributarios para Innovación",
    detail: "Cómo acceder a deducciones de impuestos por inversión en tecnología (SUNAT/CONCYTEC).",
    speaker: "Docente Nacional Invitado",
    organizer: "CONCYTEC / SUNAT",
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "06:50 PM - 07:30 PM",
    block: "BLOQUE 2: Rentabilidad y Mercados",
    title: "Panel Multilateral: Financiamiento, Mercados Globales y Alianzas",
    detail: "Financiamiento corporativo, acceso a fondos de innovación y escalamiento internacional.",
    speakers: [
      "Representante de CONCYTEC",
      "Representante del GORE Arequipa",
      "Empresario Exitoso Regional",
      "Docente Internacional III"
    ],
    glow: "border-neon-lime/20 bg-neon-lime/5",
  },
  {
    time: "07:30 PM - 08:00 PM",
    block: "Networking Estructurado",
    title: "Cóctel de Networking Corporativo & Cierre",
    detail: "Cóctel privado, bocaditos y facilitación de alianzas estratégicas.",
    glow: "border-neon-cyan/25 bg-neon-cyan/5",
  },
];
---

<Layout title="III Simposio Internacional - Desarrollo e Innovación Empresarial">


  <!-- Glass Sticky Header -->
  <header class="sticky top-0 z-45 backdrop-blur-md bg-slate-950/70 border-b border-slate-900/60 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 h-22 flex items-center justify-between">
      
      <!-- Brand Logo -->
      <a href="#" class="flex items-center space-x-3.5 group">
        <div class="w-11 h-11 rounded-2xl bg-gradient-to-tr from-neon-lime to-neon-cyan border border-neon-lime/30 flex items-center justify-center shadow-lg shadow-cyan-950/20 transition-transform duration-300 group-hover:scale-105">
          <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <div class="flex flex-col text-left">
          <span class="text-base sm:text-lg font-black font-outfit text-white tracking-tight uppercase leading-none">
            III Simposio <span class="bg-clip-text text-transparent bg-neon-lime">Internacional</span>
          </span>
          <span class="text-[8px] sm:text-[9px] text-slate-500 font-black uppercase tracking-widest mt-1">
            Desarrollo Empresarial Arequipa
          </span>
        </div>
      </a>

      <!-- Desktop Links -->
      <nav class="hidden lg:flex items-center space-x-8 text-xs font-black uppercase tracking-wider text-slate-400">
        <a href="#agenda" class="hover:text-white transition-colors">Programa</a>
        <a href="#proximamente" class="hover:text-white transition-colors">Próximamente</a>
        <a href="#faq" class="hover:text-white transition-colors">Ayuda</a>
      </nav>

      <!-- Exclusive CTA -->
      <div class="hidden lg:flex items-center">
        <a 
          href="https://docs.google.com/forms/d/e/1FAIpQLSfJX4mCbyTkkZm51t277jsRH-C06sZ8TK594r3OtW_8NPoTKw/viewform?usp=sharing&ouid=112901862161680664031"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-neon-lime text-black hover:opacity-95 shadow-md shadow-cyan-950/20 hover:scale-[1.02] active:scale-[0.98] transition-all font-black"
        >
          Postular al Registro
        </a>
      </div>

      <!-- Hamburger mobile button -->
      <button 
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-xl text-slate-400 hover:text-white hover:bg-slate-900 transition-colors focus:outline-none"
        aria-label="Abrir menú móvil"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="hamburger-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation Menu -->
    <div 
      id="mobile-nav" 
      class="hidden lg:hidden bg-slate-950/95 backdrop-blur-md border-b border-slate-900 px-6 py-6 space-y-4 shadow-xl"
    >
      <a href="#agenda" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Programa</a>
      <a href="#proximamente" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Próximamente</a>
      <a href="#faq" class="mobile-link block text-sm font-black uppercase tracking-widest text-slate-400 hover:text-white">Preguntas</a>
      <div class="pt-2">
        <a 
          href="https://docs.google.com/forms/d/e/1FAIpQLSfJX4mCbyTkkZm51t277jsRH-C06sZ8TK594r3OtW_8NPoTKw/viewform?usp=sharing&ouid=112901862161680664031"
          target="_blank"
          rel="noopener noreferrer"
          class="mobile-link w-full inline-flex items-center justify-center px-6 h-12 text-xs font-black uppercase tracking-wider rounded-xl bg-neon-lime text-black font-black"
        >
          Postular al Registro
        </a>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative pt-12 pb-24 lg:pt-20 lg:pb-36 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Content -->
        <div class="lg:col-span-7 text-center lg:text-left space-y-8 animate-[fadeIn_0.6s_ease-out]">
          
          <div class="inline-flex items-center space-x-2.5 bg-neon-lime/10 border border-neon-lime/30 px-5 py-2 rounded-full text-xs font-bold text-neon-lime tracking-widest uppercase shadow-md shadow-cyan-950/20">
            <span class="w-2.5 h-2.5 rounded-full bg-neon-lime animate-ping"></span>
            <span>Encuentro de Innovación y Creadores de Futuro</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-black tracking-tight text-white leading-[1.15] font-outfit">
            El Futuro de la Innovación:<br />
            <span class="text-neon-lime">
              Conecta, Aprende y Transforma
            </span>
          </h1>

          <p class="text-base sm:text-lg text-slate-300 font-medium leading-relaxed max-w-2xl mx-auto lg:mx-0">
            ¡Te damos la bienvenida al evento de innovación y tecnología más dinámico del macrosur! Diseñamos este espacio para conectar de forma inspiradora a <strong>emprendedores, líderes, empresas y universidades</strong>, facilitando que aprendas sobre IA de negocio, automatización y beneficios fiscales de forma sumamente sencilla y colaborativa.
          </p>

          <!-- Quick Metadata Bar -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 py-6 border-y border-slate-900 max-w-xl mx-auto lg:mx-0">
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-cyan shrink-0">
                <svg class="w-5 h-5 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
              </div>
              <div class="text-left">
                <div class="text-[10px] sm:text-xs text-slate-400 font-bold uppercase tracking-wider">Fecha</div>
                <div class="text-sm font-extrabold text-white">Miér. 1 de Julio, 2026</div>
              </div>
            </div>
            
            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-lime shrink-0">
                <svg class="w-5 h-5 text-neon-lime" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </div>
              <div class="text-left">
                <div class="text-[10px] sm:text-xs text-slate-400 font-bold uppercase tracking-wider">Horario</div>
                <div class="text-sm font-extrabold text-white">4:00 PM – 8:00 PM</div>
              </div>
            </div>

            <div class="flex items-center space-x-3.5 justify-center lg:justify-start">
              <div class="w-11 h-11 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center text-neon-cyan shrink-0">
                <svg class="w-5 h-5 text-neon-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div class="text-left">
                <div class="text-[10px] sm:text-xs text-slate-400 font-bold uppercase tracking-wider">Lugar</div>
                <div class="text-sm font-extrabold text-white">Cámara de Comercio - AQP</div>
              </div>
            </div>
          </div>

          <!-- Hero CTAs -->
          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
            <a 
              href="https://docs.google.com/forms/d/e/1FAIpQLSfJX4mCbyTkkZm51t277jsRH-C06sZ8TK594r3OtW_8NPoTKw/viewform?usp=sharing&ouid=112901862161680664031"
              target="_blank"
              rel="noopener noreferrer"
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-neon-lime text-black hover:opacity-95 shadow-xl hover:shadow-cyan-950/20 hover:scale-[1.01] active:scale-[0.99] transition-all font-black"
            >
              Postular al Registro
            </a>
            <a 
              href="#agenda" 
              class="w-full sm:w-auto inline-flex items-center justify-center px-8 h-14 text-xs font-black uppercase tracking-widest rounded-2xl bg-slate-900 border border-slate-800 text-slate-350 hover:text-white hover:bg-slate-800 transition-all"
            >
              Ver Programa Oficial
            </a>
          </div>

        </div>

        {/* Right Column: Interactive Event Console */}
        <div class="lg:col-span-5 relative flex justify-center w-full">
          <!-- Background Glow -->
          <div class="absolute inset-0 bg-gradient-to-tr from-neon-lime/20 to-neon-cyan/20 rounded-3xl blur-3xl -z-10 opacity-70 animate-pulse-slow"></div>
          
          <!-- Console Container -->
          <div class="relative w-full max-w-[420px] bg-[#020b18]/90 backdrop-blur-xl border border-slate-900/60 rounded-3xl p-7 shadow-2xl flex flex-col justify-between overflow-hidden group hover:border-neon-lime/30 transition-all duration-500 min-h-[580px]">
            
            <!-- Tech Grid overlay -->
            <div class="absolute inset-0 bg-[linear-gradient(to_right,#0e716c05_1px,transparent_1px),linear-gradient(to_bottom,#0e716c05_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
            
            <!-- Scanning Light Bar Effect -->
            <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-neon-cyan/35 to-transparent animate-[pulse_3s_infinite] pointer-events-none"></div>

            <!-- Console Header -->
            <div class="flex justify-between items-center z-10 relative border-b border-slate-900/80 pb-4">
              <div class="flex items-center space-x-2">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-ping"></span>
                <span class="w-2 h-2 rounded-full bg-emerald-500 absolute"></span>
                <span class="text-[10px] font-mono font-bold tracking-widest text-emerald-400 uppercase">Symposium Status: Active</span>
              </div>
              <span class="text-[9px] font-mono text-slate-500 bg-slate-950/80 border border-slate-850 px-2.5 py-1 rounded-md uppercase tracking-wider">
                Console v1.0.4
              </span>
            </div>

            <!-- Central Content: Dashboard Widget -->
            <div class="my-5 space-y-6 z-10 relative flex-grow flex flex-col justify-center text-left">
              
              <!-- Section 1: Event Date & Countdown -->
              <div class="space-y-3">
                <span class="text-[10px] font-bold text-neon-cyan uppercase tracking-wider block">Cuenta Regresiva para el Evento</span>
                
                {/* Countdown Ticker */}
                <div class="grid grid-cols-4 gap-2.5 text-center">
                  <div class="bg-slate-950/80 border border-slate-900/60 rounded-xl p-2.5 shadow-inner">
                    <div id="countdown-days" class="text-xl sm:text-2xl font-black text-white font-mono">00</div>
                    <div class="text-[8px] text-slate-500 font-bold uppercase tracking-wide mt-0.5">Días</div>
                  </div>
                  <div class="bg-slate-950/80 border border-slate-900/60 rounded-xl p-2.5 shadow-inner">
                    <div id="countdown-hours" class="text-xl sm:text-2xl font-black text-white font-mono">00</div>
                    <div class="text-[8px] text-slate-500 font-bold uppercase tracking-wide mt-0.5">Horas</div>
                  </div>
                  <div class="bg-slate-950/80 border border-slate-900/60 rounded-xl p-2.5 shadow-inner">
                    <div id="countdown-minutes" class="text-xl sm:text-2xl font-black text-white font-mono">00</div>
                    <div class="text-[8px] text-slate-500 font-bold uppercase tracking-wide mt-0.5">Min</div>
                  </div>
                  <div class="bg-slate-950/80 border border-slate-900/60 rounded-xl p-2.5 shadow-inner animate-[pulse_2s_infinite]">
                    <div id="countdown-seconds" class="text-xl sm:text-2xl font-black text-neon-lime font-mono">00</div>
                    <div class="text-[8px] text-slate-500 font-bold uppercase tracking-wide mt-0.5">Seg</div>
                  </div>
                </div>
              </div>

              <!-- Section 2: Real-time Capacity Meter -->
              <div class="space-y-3 bg-slate-950/40 border border-slate-900/60 rounded-2xl p-4 shadow-inner">
                <div class="flex justify-between items-center text-xs">
                  <span class="font-bold text-slate-300">Aforo Presencial CCIA</span>
                  <span id="aforo-percentage" class="font-bold text-neon-lime uppercase tracking-wide text-[10px]">88% Completado</span>
                </div>
                
                {/* Progress Bar */}
                <div class="w-full h-2.5 bg-slate-900/85 rounded-full overflow-hidden border border-slate-800/80">
                  <div id="aforo-bar" class="h-full bg-gradient-to-r from-neon-lime to-neon-cyan rounded-full transition-all duration-300 shadow-md" style="width: 88%;"></div>
                </div>

                <div class="flex justify-between items-center text-[10px] text-slate-400 font-medium">
                  <div class="flex items-center space-x-1 bg-slate-950/80 border border-slate-900/80 px-2 py-0.5 rounded-lg select-none">
                    <button 
                      type="button" 
                      id="btn-aforo-dec" 
                      class="w-4 h-4 rounded flex items-center justify-center text-[10px] font-bold text-slate-400 hover:text-white hover:bg-slate-900 active:scale-90 transition-all focus:outline-none cursor-pointer"
                      title="Disminuir Aforo"
                    >
                      -
                    </button>
                    <span id="aforo-count" class="font-mono font-bold text-white text-[11px] w-6 text-center">88</span>
                    <span class="text-slate-500 text-[10px]">/ 100</span>
                    <button 
                      type="button" 
                      id="btn-aforo-inc" 
                      class="w-4 h-4 rounded flex items-center justify-center text-[10px] font-bold text-slate-400 hover:text-white hover:bg-slate-900 active:scale-90 transition-all focus:outline-none cursor-pointer"
                      title="Incrementar Aforo"
                    >
                      +
                    </button>
                  </div>
                  <span id="aforo-status-msg" class="text-neon-cyan font-bold animate-[pulse_1.5s_infinite]">¡Últimos 12 Cupos Libres!</span>
                </div>

                {/* Range Slider for Interactive Capacity Modification */}
                <div class="pt-0.5">
                  <input 
                    type="range" 
                    id="aforo-slider" 
                    min="0" 
                    max="100" 
                    value="88" 
                    class="w-full h-1 bg-slate-900 rounded-lg appearance-none cursor-pointer focus:outline-none accent-[#14a39b]"
                  />
                </div>
              </div>

              <!-- Section 3: Event Features Grid -->
              <div class="space-y-3">
                <span class="text-[10px] font-bold text-neon-cyan uppercase tracking-wider block">Estadísticas Clave del Simposio</span>
                
                <div class="grid grid-cols-3 gap-2">
                  <div class="bg-slate-950/70 border border-slate-900/60 rounded-xl p-2.5 text-center flex flex-col justify-center">
                    <span class="text-base font-black text-white font-outfit">100+</span>
                    <span class="text-[8px] text-slate-400 font-bold uppercase tracking-tight mt-0.5 leading-snug">Líderes de Empresa</span>
                  </div>
                  <div class="bg-slate-950/70 border border-slate-900/60 rounded-xl p-2.5 text-center flex flex-col justify-center">
                    <span class="text-base font-black text-neon-cyan font-outfit">3+</span>
                    <span class="text-[8px] text-slate-400 font-bold uppercase tracking-tight mt-0.5 leading-snug">Ponentes Internac.</span>
                  </div>
                  <div class="bg-slate-950/70 border border-slate-900/60 rounded-xl p-2.5 text-center flex flex-col justify-center">
                    <span class="text-xs sm:text-sm font-black text-neon-lime font-outfit uppercase">Gratuito</span>
