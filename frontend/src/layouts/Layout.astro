---
import '../index.css';

interface Props {
  title: string;
  description?: string;
}

const { 
  title = "III Simposio Internacional - Desarrollo e Innovación Empresarial",
  description = "Encuentro de innovación y tecnología más dinámico del macrosur en Arequipa. Conéctate con líderes empresariales, aprende de IA aplicada y conoce beneficios fiscales de SUNAT y CONCYTEC."
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Premium Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- SEO Optimization -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://www.unsa.edu.pe/simposio/" />
    
    <!-- OpenGraph Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.unsa.edu.pe/simposio/" />
    <meta property="og:image" content={`${baseUrl}og-image.jpg`} />
    <meta property="og:locale" content="es_PE" />
    
    <!-- Theme Color and Favicons -->
    <meta name="theme-color" content="#030712" />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />

    <!-- Theme Detection and Initialization (avoids flash of unstyled theme) -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'light'; // Default theme is light
      };
      
      const theme = getThemePreference();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 dark:bg-slate-950 dark:text-slate-300 font-sans antialiased overflow-x-hidden relative selection:bg-brand-teal selection:text-white transition-colors duration-300">
    
    <!-- ── Ambient Premium Glow Orbs Background ── -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none -z-25 min-h-screen">
      <!-- Flyer blue pulsing glow, upper left -->
      <div class="absolute top-[-10%] left-[-10%] w-[60vw] h-[60vw] rounded-full bg-flyer-blue-800/5 dark:bg-flyer-blue-800/20 blur-[120px] animate-float-slow transition-colors duration-300"></div>
      
      <!-- Brand Teal Light pulsing glow, upper right -->
      <div class="absolute top-[5%] right-[-15%] w-[55vw] h-[55vw] rounded-full bg-brand-teal-light/5 dark:bg-brand-teal-light/8 blur-[130px] animate-float-delayed transition-colors duration-300"></div>
      
      <!-- Brand Teal pulsing glow, middle -->
      <div class="absolute top-[35%] left-[20%] w-[50vw] h-[50vw] rounded-full bg-brand-teal/2 dark:bg-brand-teal/4 blur-[150px] animate-pulse-slow transition-colors duration-300"></div>
      
      <!-- Brand Teal pulsing glow, lower right -->
      <div class="absolute bottom-[10%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-brand-teal/3 dark:bg-brand-teal/6 blur-[140px] animate-float-slow transition-colors duration-300"></div>
      
      <!-- Deep Blue pulsing glow, bottom left -->
      <div class="absolute bottom-[-15%] left-[-15%] w-[55vw] h-[55vw] rounded-full bg-flyer-blue-900/5 dark:bg-flyer-blue-900/20 blur-[120px] animate-float-delayed transition-colors duration-300"></div>
    </div>

    <!-- Layout Main Wrapper -->
    <div class="relative z-10">
      <slot />
    </div>

  </body>
</html>
