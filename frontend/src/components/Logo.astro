---
interface Props {
  variant?: 'light' | 'dark' | 'teal';
  size?: 'sm' | 'md' | 'lg';
  showSubtitle?: boolean;
  className?: string;
}

const {
  variant = 'light',
  size = 'md',
  showSubtitle = true,
  className = '',
} = Astro.props;

// Color mapping based on guidelines
// 'light' -> White bars and text (for dark backgrounds)
// 'dark' -> `#141E42` (brand-blue) bars and text (for white backgrounds)
// 'teal' -> `#0E716C` (brand-teal) bars and text
const colorClasses = {
  light: 'text-white',
  dark: 'text-brand-blue',
  teal: 'text-brand-teal',
};

// Size mapping for the vertical bars
const barSizes = {
  sm: 'w-[4px] h-7 rounded-[1px]',
  md: 'w-[6px] h-10 rounded-[2px]',
  lg: 'w-[8px] h-[52px] rounded-[3px]',
};

// Gap mapping between bars
const barGaps = {
  sm: 'gap-[3px]',
  md: 'gap-[4px]',
  lg: 'gap-[6px]',
};

// Size mapping for the main title text
const titleSizes = {
  sm: 'text-sm sm:text-base leading-[0.9] tracking-tight',
  md: 'text-lg sm:text-xl leading-[0.9] tracking-tight',
  lg: 'text-3xl sm:text-[34px] leading-[0.9] tracking-tight',
};

// Size mapping for the subtitle text
const subtitleSizes = {
  sm: 'text-[7px] leading-tight mt-1',
  md: 'text-[9px] leading-tight mt-1.5',
  lg: 'text-xs sm:text-[13px] leading-tight mt-2.5',
};

// Additional padding for alignment
const textPaddings = {
  sm: 'pl-2',
  md: 'pl-3.5',
  lg: 'pl-[18px]',
};
---

<div class={`flex flex-col text-left select-none ${colorClasses[variant]} ${className}`}>
  <div class="flex items-center">
    <!-- Three vertical bars representing "III" -->
    <div class={`flex ${barGaps[size]} shrink-0`}>
      <div class={`${barSizes[size]} bg-current`}></div>
      <div class={`${barSizes[size]} bg-current`}></div>
      <div class={`${barSizes[size]} bg-current`}></div>
    </div>
    
    <!-- Title Text Block ("SIMPOSIO INTERNACIONAL") -->
    <div class={`flex flex-col justify-center text-left pl-3 font-outfit uppercase`}>
      <span class={`${titleSizes[size]} font-black`}>Simposio</span>
      <span class={`${titleSizes[size]} font-extrabold`}>Internacional</span>
    </div>
  </div>
  
  <!-- Subtitle line aligned under the text block -->
  {showSubtitle && (
    <div class={`${textPaddings[size]} w-full`}>
      <p class={`${subtitleSizes[size]} font-sans font-medium opacity-90 tracking-wide`}>
        Tecnología, innovación y desarrollo empresarial.
      </p>
    </div>
  )}
</div>
