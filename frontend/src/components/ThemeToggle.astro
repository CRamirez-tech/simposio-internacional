---
// Reusable Theme Toggle Component for the Symposium
---

<button
  type="button"
  class="relative inline-flex items-center justify-center w-10 h-10 rounded-xl bg-slate-200/50 hover:bg-slate-200/80 border border-slate-300/60 text-slate-700 hover:text-slate-900 dark:bg-slate-900/60 dark:hover:bg-slate-900/80 dark:border-slate-800/60 dark:text-slate-350 dark:hover:text-white transition-all duration-300 focus:outline-none hover:scale-[1.05] active:scale-[0.95] backdrop-blur-md shadow-md cursor-pointer theme-toggle select-none"
  aria-label="Cambiar tema de color"
>
  <!-- Sun Icon (visible in Dark Mode) -->
  <svg
    class="w-5 h-5 transition-all duration-500 rotate-90 scale-0 dark:rotate-0 dark:scale-100 absolute"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
  >
    <circle cx="12" cy="12" r="4" fill="currentColor"></circle>
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
  </svg>
  
  <!-- Moon Icon (visible in Light Mode) -->
  <svg
    class="w-5 h-5 transition-all duration-500 rotate-0 scale-100 dark:rotate-90 dark:scale-0 absolute"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    viewBox="0 0 24 24"
  >
    <path stroke-linecap="round" stroke-linejoin="round" fill="currentColor" d="M12 3a9 9 0 009 9 9 9 0 11-9-9z"></path>
  </svg>
</button>

<script is:inline>
  // Setup theme toggle logic for all buttons with class "theme-toggle"
  (function() {
    const setupThemeToggles = () => {
      const toggles = document.querySelectorAll('.theme-toggle');
      
      toggles.forEach(toggle => {
        // Remove existing listener by cloning
        const newToggle = toggle.cloneNode(true);
        toggle.parentNode.replaceChild(newToggle, toggle);
        
        newToggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark');
          if (isDark) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
          }
        });
      });
    };

    // Run immediately
    setupThemeToggles();

    // Listen for storage changes in other tabs
    window.addEventListener('storage', (e) => {
      if (e.key === 'theme') {
        if (e.newValue === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      }
    });
  })();
</script>
