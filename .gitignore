# ==========================================
# III Simposio Internacional - .gitignore
# ==========================================

# ── 1. DEPENDENCIAS (Node.js) ──
node_modules/
/jspm_packages/
/web_modules/
.npm/

# ── 2. CARPETAS DE COMPILACIÓN Y CACHÉ (Astro / Vite) ──
# Carpeta de compilación estática (outDir)
build/
dist/

# Caché interna de Astro y compilador
.astro/
.cache/
.vite/
.parcel-cache/
*.tsbuildinfo

# ── 3. ARCHIVOS DE ENTORNO (Seguridad) ──
# Nunca subir credenciales ni variables locales de entorno
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# ── 4. LOGS Y REPORTES DE ERRORES ──
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids
*.pid
*.seed
*.pid.lock

# ── 5. SISTEMA OPERATIVO Y EDITORES (IDE) ──
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editores de código comunes
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
